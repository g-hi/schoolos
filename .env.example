# ─────────────────────────────────────────────────────────────────────────────
# SchoolOS – Environment Variables
#
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ───────────────────────────────────────────────────────────────
# asyncpg driver is required for async SQLAlchemy
DATABASE_URL=postgresql+asyncpg://schoolos_user:schoolos_pass@localhost:5432/schoolos

# ── Redis (cache + job queue) ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security ────────────────────────────────────────────────────────────────
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# ── Twilio (WhatsApp + SMS) ────────────────────────────────────────────────
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=+1234567890

# ── SendGrid (Email) ───────────────────────────────────────────────────────
# Get this from https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@yourschool.com

# ── LLM (OpenAI or compatible) ────────────────────────────────────────────
# Used ONLY for summaries and NL command parsing — not for decisions
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_MODEL=gpt-4o-mini
# Hard cap per API call — cost control
LLM_MAX_TOKENS=500

# ── App ────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO
